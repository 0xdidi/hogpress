# Composer: vendor/ is NOT committed (it would include heavy dev tooling).
# composer.lock IS committed for reproducible installs. The distribution ZIP
# (Phase 7) is built with `composer install --no-dev` so the shipped plugin
# vendors posthog-php and needs no Composer step at runtime.
/vendor/
